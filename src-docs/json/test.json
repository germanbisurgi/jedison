{
  "$ref": "#/$defs/schema",
  "$defs": {
    "schemaBase": {
      "type": "object",
      "x-deactivateNonRequired": true,
      "x-propGroupOrder": ["Common", "Composition", "Options"],
      "properties": {
        "type": {
          "type": "string",
          "readOnly": true,
          "x-hidden": true,
          "x-propGroup": "Common"
        },
        "title": {
          "type": "string",
          "x-propGroup": "Common"
        },
        "description": {
          "type": "string",
          "x-format": "textarea",
          "x-propGroup": "Common"
        },
        "enum": {
          "type": "array",
          "x-propGroup": "Common"
        },
        "oneOf": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/schema"
          },
          "x-propGroup": "Composition"
        },
        "anyOf": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/schema"
          },
          "x-propGroup": "Composition"
        },
        "x-format": {
          "x-propGroup": "Options",
          "type": "string"
        },
        "x-titleIconClass": {
          "type": "string",
          "x-propGroup": "Options"
        },
        "x-titleTemplate": {
          "type": "string",
          "x-propGroup": "Options"
        },
        "x-switcherTitle": {
          "type": "string",
          "x-propGroup": "Options"
        },
        "x-grid": {
          "x-propGroup": "Options",
          "type": "object",
          "properties": {
            "columns": {
              "type": "number"
            }
          }
        },
        "x-messages": {
          "x-propGroup": "Options",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "x-enumTitles": {
          "x-propGroup": "Options",
          "x-format": "table",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "x-titleHidden": {
          "x-propGroup": "Options",
          "type": "boolean"
        },
        "x-enableCollapseToggle": {
          "x-propGroup": "Options",
          "type": "boolean"
        },
        "x-startCollapsed": {
          "x-propGroup": "Options",
          "type": "boolean"
        },
        "x-sortable": {
          "x-propGroup": "Options",
          "type": "boolean"
        },
        "x-showErrors": {
          "x-propGroup": "Options",
          "type": "boolean"
        },
        "x-deactivateNonRequired": {
          "x-propGroup": "Options",
          "type": "boolean"
        },
        "x-assertFormat": {
          "x-propGroup": "Options",
          "type": "boolean"
        }
      }
    },

    "schema": {
      "x-embedSwitcher": true,
      "x-discriminator": "type",
      "oneOf": [
        { "$ref": "#/$defs/schemaString" },
        { "$ref": "#/$defs/schemaNumber" },
        { "$ref": "#/$defs/schemaInteger" },
        { "$ref": "#/$defs/schemaBoolean" },
        { "$ref": "#/$defs/schemaObject" },
        { "$ref": "#/$defs/schemaArray" },
        { "$ref": "#/$defs/schemaNoType" }
      ]
    },

    "schemaString": {
      "$ref": "#/$defs/schemaBase",
      "x-switcherTitle": "String",
      "x-propGroupOrder": ["Common", "String", "Composition", "Options"],
      "required": ["type"],
      "properties": {
        "type": { "enum": ["string"], "x-propGroup": "Common" },
        "default": {
          "type": "string",
          "x-propGroup": "Common"
        },
        "enum": {
          "x-format": "table",
          "x-propGroup": "Common",
          "items": {
            "type": "string"
          }
        },
        "format": {
          "type": "string",
          "x-propGroup": "String"
        },
        "minLength": {
          "type": "integer",
          "minimum": 0,
          "x-propGroup": "String"
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0,
          "x-propGroup": "String"
        },
        "pattern": {
          "type": "string",
          "format": "regex",
          "x-propGroup": "String"
        }
      }
    },

    "schemaNumber": {
      "$ref": "#/$defs/schemaBase",
      "x-switcherTitle": "Number",
      "x-propGroupOrder": ["Common", "Numeric", "Composition", "Options"],
      "required": ["type"],
      "properties": {
        "type": { "enum": ["number"], "x-propGroup": "Common" },
        "default": {
          "type": "number",
          "x-propGroup": "Common"
        },
        "maximum": {
          "type": "number",
          "x-propGroup": "Numeric"
        },
        "minimum": {
          "type": "number",
          "x-propGroup": "Numeric"
        },
        "multipleOf": {
          "type": "number",
          "exclusiveMinimum": 0,
          "x-propGroup": "Numeric"
        },
        "exclusiveMaximum": {
          "type": "number",
          "x-propGroup": "Numeric"
        },
        "exclusiveMinimum": {
          "type": "number",
          "x-propGroup": "Numeric"
        }
      }
    },

    "schemaInteger": {
      "$ref": "#/$defs/schemaBase",
      "x-switcherTitle": "Integer",
      "x-propGroupOrder": ["Common", "Numeric", "Composition", "Options"],
      "required": ["type"],
      "properties": {
        "type": { "enum": ["integer"], "x-propGroup": "Common" },
        "default": {
          "type": "integer",
          "x-propGroup": "Common"
        },
        "maximum": {
          "type": "number",
          "x-propGroup": "Numeric"
        },
        "minimum": {
          "type": "number",
          "x-propGroup": "Numeric"
        },
        "multipleOf": {
          "type": "number",
          "exclusiveMinimum": 0,
          "x-propGroup": "Numeric"
        },
        "exclusiveMaximum": {
          "type": "number",
          "x-propGroup": "Numeric"
        },
        "exclusiveMinimum": {
          "type": "number",
          "x-propGroup": "Numeric"
        }
      }
    },

    "schemaBoolean": {
      "$ref": "#/$defs/schemaBase",
      "x-switcherTitle": "Boolean",
      "x-propGroupOrder": ["Common", "Composition", "Options"],
      "required": ["type"],
      "properties": {
        "type": { "enum": ["boolean"], "x-propGroup": "Common" },
        "default": {
          "type": "boolean",
          "x-propGroup": "Common"
        }
      }
    },

    "schemaObject": {
      "$ref": "#/$defs/schemaBase",
      "x-switcherTitle": "Object",
      "x-propGroupOrder": ["Common", "Object", "Composition", "Options"],
      "required": ["type"],
      "properties": {
        "type": { "enum": ["object"], "x-propGroup": "Common" },
        "default": {
          "type": "object",
          "x-format": "json",
          "x-propGroup": "Common"
        },
        "required": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          },
          "x-format": "choices",
          "x-enumSource": "properties",
          "x-propGroup": "Object"
        },
        "properties": {
          "type": "object",
          "x-propGroup": "Object",
          "additionalProperties": {
            "$ref": "#/$defs/schema",
            "x-startCollapsed": true
          }
        },
        "dependentRequired": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "title": "property",
              "type": "string"
            },
            "x-format": "choices",
            "x-choicesOptions": {
              "addChoices": true
            }
          },
          "x-propGroup": "Object"
        },
        "dependentSchemas": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/schema"
          },
          "x-propGroup": "Object"
        },
        "maxProperties": {
          "type": "integer",
          "minimum": 0,
          "x-propGroup": "Object"
        },
        "minProperties": {
          "type": "integer",
          "minimum": 0,
          "x-propGroup": "Object"
        },
        "patternProperties": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/schema"
          },
          "x-propGroup": "Object"
        }
      }
    },

    "schemaArray": {
      "$ref": "#/$defs/schemaBase",
      "x-switcherTitle": "Array",
      "x-propGroupOrder": ["Common", "Array", "Composition", "Options"],
      "required": ["type"],
      "properties": {
        "type": { "enum": ["array"], "x-propGroup": "Common" },
        "default": {
          "type": "array",
          "x-format": "json",
          "x-propGroup": "Common"
        },
        "items": {
          "$ref": "#/$defs/schema",
          "x-propGroup": "Array"
        },
        "minItems": {
          "type": "integer",
          "minimum": 0,
          "x-propGroup": "Array"
        },
        "maxItems": {
          "type": "integer",
          "minimum": 0,
          "x-propGroup": "Array"
        },
        "uniqueItems": {
          "type": "boolean",
          "x-propGroup": "Array"
        },
        "contains": {
          "$ref": "#/$defs/schema",
          "x-propGroup": "Array"
        },
        "maxContains": {
          "type": "integer",
          "minimum": 0,
          "x-propGroup": "Array"
        },

        "minContains": {
          "type": "integer",
          "minimum": 0,
          "x-propGroup": "Array"
        },

        "prefixItems": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/schema"
          },
          "x-propGroup": "Array"
        }
      }
    },
    "schemaNoType": {
      "$ref": "#/$defs/schemaBase",
      "x-switcherTitle": "No Type",
      "not": {
        "required": ["type"]
      }
    }
  }
}