{
  "title": "Cron Schedule Configurator",
  "type": "object",
  "required": ["minute", "hour", "dayOfMonth", "month", "dayOfWeek"],
  "properties": {
    "minute": {
      "type": "string",
      "title": "Minute",
      "enum": [
        "*",
        "*/5",
        "*/10",
        "*/15",
        "*/30",
        "0"
      ],
      "default": "*"
    },
    "hour": {
      "type": "string",
      "title": "Hour",
      "enum": [
        "*",
        "*/1",
        "*/2",
        "*/6",
        "*/12",
        "0"
      ],
      "default": "*"
    },
    "dayOfMonth": {
      "type": "string",
      "title": "Day of Month",
      "enum": [
        "*",
        "1",
        "15",
        "L"
      ],
      "default": "*"
    },
    "month": {
      "type": "string",
      "title": "Month",
      "enum": [
        "*",
        "1",
        "4",
        "7",
        "10"
      ],
      "default": "*"
    },
    "dayOfWeek": {
      "type": "string",
      "title": "Day of Week",
      "enum": [
        "*",
        "1",
        "2",
        "3",
        "4",
        "5",
        "6",
        "0"
      ],
      "options": {
        "enum_titles": [
          "Every day",
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday",
          "Saturday",
          "Sunday"
        ]
      },
      "default": "*"
    },
    "cronPreview": {
      "type": "string",
      "title": "Cron Expression",
      "readOnly": true,
      "default": "* * * * *"
    }
  }
}