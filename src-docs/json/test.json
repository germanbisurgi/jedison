{
  "title": "Neozoen",
  "type": "object",
  "x-options": {
    "format": "grid",
    "grid": {
      "columns": 12
    }
  },
  "properties": {
    "marderhund": {
      "title": "Marderhund",
      "$ref": "#\/$defs/custom_vorkommen_jungtiere_anzahl",
      "properties": {
        "vk": {
          "title": "Kam die Art im **JJ 2025/2026** in Ihrem Revier vor?"
        },
        "jungtiere": {
          "title": "Konnten Sie im **JJ 2025/2026** Jungtiere beobachten?"
        },
        "gehecke": {
          "title": "Anzahl Gehecke (Wurfbaue):"
        }
      }
    }
  },
  "$defs": {
    "custom_vorkommen_jungtiere_anzahl": {
      "$ref": "#/$defs/global/vorkommen",
      "x-options": {
        "format": "grid"
      },
      "properties": {
        "jungtiere": {
          "title": "Konnten Sie im aktuellen Jagdjahr Jungtiere beobachten?"
        },
        "gehecke": {
          "title": "Anzahl Gehecke:"
        }
      },
      "if": {
        "properties": {
          "vk": {
            "const": "ja"
          }
        }
      },
      "then": {
        "properties": {
          "jungtiere": {
            "type": "string",
            "enum": [
              "ja",
              "nein"
            ],
            "x-options": {
              "enforceEnumDefault": false,
              "format": "radios-inline",
              "enumTitles": [
                "ja",
                "nein"
              ]
            }
          },
          "gehecke": {
            "type": "integer",
            "x-enforceConst": true
          }
        },
        "if": {
          "properties": {
            "jungtiere": {
              "const": "ja"
            }
          }
        },
        "then": {
          "properties": {
            "gehecke": {
              "minimum": 0,
              "maximum": 9999
            }
          }
        },
        "else": {
          "properties": {
            "gehecke": {
              "const": 0,
              "x-enforceConst": true,
              "readOnly": true
            }
          }
        }
      },
      "else": {
        "if": {
          "properties": {
            "vk": {
              "const": "nein"
            }
          }
        },
        "then": {
          "properties": {
            "jungtiere": {
              "type": "string",
              "default": "",
              "const": "",
              "readOnly": true,
              "x-enforceConst": true,
              "description": "nein"
            },
            "gehecke": {
              "type": "integer",
              "const": 0,
              "x-enforceConst": true,
              "readOnly": true
            }
          }
        },
        "else": {
          "if": {
            "properties": {
              "vk": {
                "const": "unbekannt"
              }
            }
          },
          "then": {
            "properties": {
              "jungtiere": {
                "type": "string",
                "default": "",
                "const": "",
                "readOnly": true,
                "x-enforceConst": true,
                "description": "unbekannt"
              },
              "gehecke": {
                "type": "string",
                "default": "",
                "const": "",
                "readOnly": true,
                "x-enforceConst": true,
                "description": "unbekannt"
              }
            }
          },
          "else": {
            "properties": {
              "jungtiere": {
                "type": "string",
                "default": "",
                "const": "",
                "readOnly": true,
                "x-enforceConst": true,
                "description": "keine Angabe"
              },
              "gehecke": {
                "type": "string",
                "default": "",
                "const": "",
                "readOnly": true,
                "x-enforceConst": true,
                "description": "keine Angabe"
              }
            }
          }
        }
      }
    }
  }
}