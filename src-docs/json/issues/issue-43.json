{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Issue 43 - Nav badge not cleared after cross-field constraint errors are resolved",
  "description": "After switching the frame back to J2000 the error badge on the 'Source 1' nav-vertical tab must disappear.",
  "type": "object",
  "x-format": "nav-horizontal",
  "properties": {
    "targets": {
      "title": "Targets",
      "x-discriminator": "mode",
      "x-switcherInput": "select",
      "x-embedSwitcher": true,
      "anyOf": [
        {
          "x-switcherTitle": "Branch A",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "sources"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "const": "a",
              "default": "a",
              "x-hidden": true
            },
            "sources": {
              "title": "Sources",
              "type": "array",
              "x-format": "nav-vertical",
              "default": [
                {
                  "frame": "J2000",
                  "lng1": "19:39:25.026661"
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "frame": {
                    "type": "string",
                    "enum": [
                      "J2000",
                      "GALACTIC"
                    ],
                    "default": "J2000"
                  },
                  "lng1": {
                    "type": "string",
                    "default": "19:39:25.026661",
                    "x-coordinate-lng": true
                  }
                }
              }
            }
          }
        },
        {
          "x-switcherTitle": "Branch B",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "const": "b",
              "default": "b",
              "x-hidden": true
            }
          }
        }
      ]
    },
    "common": {
      "title": "Common",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "default": "test"
        }
      }
    }
  }
}
