{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Form Example",
  "type": "object",
  "properties": {
    "size": {
      "title": "Size",
      "type": "string",
      "enum": ["large", "medium", "small"],
      "default": "medium"
    },
    "element_b": {
      "title": "Element B",
      "type": "string"
    },
    "element_d": {
      "title": "Element D",
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "size": { "const": "large" } },
        "required": ["size"]
      },
      "then": {
        "properties": { "element_b": { "type": "string" } },
        "required": ["element_b"]
      },
      "else": {
        "properties": { "element_b": { "type": "string", "x-hidden": true } }
      }
    },
    {
      "if": {
        "properties": { "size": { "const": "large" } },
        "required": ["size"]
      },
      "then": {
        "properties": { "element_d": { "type": "string" } },
        "required": ["element_d"]
      },
      "else": {
        "properties": { "element_d": { "type": "string", "x-hidden": true } }
      }
    }
  ]
}
