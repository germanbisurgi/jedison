{
  "type": "object",
  "required": [
    "test"
  ],
  "properties": {
    "test": {
      "$ref": "#/$defs/global/myDef"
    }
  },
  "$defs": {
    "global": {
      "myDef": {
        "type": "object",
        "required": [
          "propA"
        ],
        "properties": {
          "propA": {
            "type": "string",
            "enum": [
              "yes",
              "no",
              "unknown",
              "none"
            ],
            "x-enumTitles": [
              "yes",
              "no",
              "unknown",
              "none"
            ],
            "x-enforceEnum": false,
            "x-format": "radios-inline"
          }
        },
        "if": {
          "properties": {
            "propA": {
              "anyOf": [
                {
                  "const": "yes"
                },
                {
                  "const": "no"
                }
              ]
            }
          }
        },
        "then": {
          "properties": {
            "propB": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          },
          "if": {
            "properties": {
              "propA": {
                "const": "no"
              }
            }
          },
          "then": {
            "properties": {
              "propB": {
                "type": "integer",
                "const": 0,
                "readOnly": true
              }
            }
          }
        },
        "else": {
          "properties": {
            "propB": {
              "type": "null",
              "const": null
            }
          }
        }
      }
    }
  }
}
